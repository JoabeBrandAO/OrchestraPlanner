# === OrchestraPlanner — variáveis de ambiente (EXEMPLO) ===
# Copie este arquivo para `.env` e preencha os valores reais.
# NUNCA comite o `.env` (já está no .gitignore).

# --- Banco de dados (PostgreSQL) ---
# Local (docker-compose):
#   postgres://postgres:postgres@localhost:5432/orchestraplanner
# Neon (produção) — string com pooling + SSL:
#   postgres://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require
DATABASE_URL=

# --- Clerk (autenticação) — issue #4 ---
# Pegue em https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Rotas de auth (opcionais; estes são os defaults usados pelo app)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
